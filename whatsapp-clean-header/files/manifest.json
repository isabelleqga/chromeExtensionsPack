{
  "manifest_version": 3,
  "name": "WhatsApp Clean Header",
  "version": "5.0",
  "description": "Possibilita ocultar os ícones de Status, Canais, Comunidades, Meta AI e Filtros no WhatsApp Web.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ]
}