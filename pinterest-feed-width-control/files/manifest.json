{
  "manifest_version": 3,
  "name": "Pinterest Column Control",
  "version": "1.0",
  "description": "Controla a quantidade a largura do feed da página inicial do Pinterest.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.pinterest.com/*",
    "*://*.pinterest.pt/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.pinterest.com/*", "*://*.pinterest.pt/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}