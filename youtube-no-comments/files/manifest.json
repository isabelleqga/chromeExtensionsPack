{
  "manifest_version": 3,
  "name": "YouTube No Comments",
  "version": "1.0",
  "description": "Oculta seção de comentários e possibilita ocultar itens da barra lateral.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ]
}